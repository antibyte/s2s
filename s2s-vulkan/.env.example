# ── Image (GHCR) ─────────────────────────────────────────────────────
# Set GHCR_OWNER to your GitHub user/org (lowercase).
GHCR_OWNER=your-github-user
IMAGE=ghcr.io/your-github-user/s2s-vulkan
TAG=latest

# ── Runtime ──────────────────────────────────────────────────────────
S2S_PORT=8765
# websocket = raw PCM for web lab; realtime = OpenAI-style events
S2S_MODE=websocket
S2S_GPU=auto
# GGML_BACKEND=Vulkan0
RUST_LOG=info

# ── First-boot model download ────────────────────────────────────────
S2S_DOWNLOAD_MODELS=auto
S2S_DOWNLOAD_FORCE=0
S2S_DOWNLOAD_WHISPER=true
S2S_DOWNLOAD_LLM=true
S2S_DOWNLOAD_TTS=false

# Whisper (ggerganov/whisper.cpp on Hugging Face)
S2S_WHISPER_PRESET=small
# S2S_WHISPER_HF_FILE=ggml-small.bin
# S2S_WHISPER_MODEL_URL=https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-small.bin

# LLM GGUF
S2S_LLM_HF_REPO=Qwen/Qwen2.5-1.5B-Instruct-GGUF
S2S_LLM_HF_FILE=qwen2.5-1.5b-instruct-q4_k_m.gguf
# S2S_LLM_MODEL_URL=https://huggingface.co/.../resolve/main/model.gguf
# HF_TOKEN=hf_xxx   # only for gated models

# Extra: comma-separated url=>relpath under /models
# S2S_DOWNLOAD_EXTRA=https://example.com/x.bin=>extras/x.bin

# Backend file names inside the volume (must match downloads)
WHISPER_MODEL_FILE=ggml-small.bin
LLAMA_MODEL_FILE=qwen2.5-1.5b-instruct-q4_k_m.gguf

# ── Host GIDs for /dev/dri (Linux) ───────────────────────────────────
VIDEO_GID=44
RENDER_GID=109

# ── Optional backend URLs if not using compose profiles ──────────────
# S2S_WHISPER_URL=http://host.docker.internal:8082
# S2S_LLM_URL=http://host.docker.internal:8081/v1

# ── Web test UI (profile: web) ───────────────────────────────────────
# docker compose --profile web up -d --build
WEB_PORT=8088
